# ============================================================
# Data Warehouse E-commerce — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores
# ============================================================

# --- PostgreSQL Local (Docker) ---
POSTGRES_USER=dw_user
POSTGRES_PASSWORD=dw_password
POSTGRES_DB=ecommerce
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# --- Supabase (Produção) ---
# Preencher quando for fazer o deploy pro Supabase
SUPABASE_HOST=
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=

# --- Ambiente (local | prod) ---
ENV=local
